# Optional external API URL. Leave blank to use this app's own Next API routes.
NEXT_PUBLIC_API_URL=https://team-white-draft-kit-ui-backend.onrender.com

# Optional API key header. Leave blank unless your deployment enforces it.
NEXT_PUBLIC_API_KEY=

# MongoDB connection used by the Draft Kit backend routes.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Optional database name override.
MONGODB_DB_NAME=draftkit
